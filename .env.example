POSTGRES_USER=aiagent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aiagent
DATABASE_URL=postgresql+psycopg://aiagent:changeme@postgres:5432/aiagent

JWT_SECRET=replace-with-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 32-byte urlsafe base64 key for Fernet — generate with: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

CORS_ORIGINS=http://localhost:3000

# Optional default keys (admins can override in UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

NEXT_PUBLIC_API_URL=http://localhost:8000

# MinIO object storage
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=changeme-minio
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET_DOCS=docs
MINIO_BUCKET_ATTACHMENTS=chat-attachments
MINIO_BUCKET_IMAGES=images
MINIO_USE_SSL=false
MINIO_PRESIGN_EXPIRY=3600
